# Example environment for the prevly daemon. Copy to .env (which is gitignored)
# and load it via systemd EnvironmentFile or your shell. All sensitive values
# live here, never in the YAML config files.

# Webhook HMAC secret (matches github.webhook_secret_env in config.yaml).
PREVLY_WEBHOOK_SECRET=replace-with-a-long-random-string

# Secrets referenced by name from .prevly.yml (host config maps name -> env:VAR).
# These must be NON-PRODUCTION values; previews must never carry prod secrets.
PREVLY_SECRET_SA_KEY=replace-with-a-non-prod-value

# DNS-01 provider credentials for CertMagic (choose one provider).
# Route53:
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION=eu-west-1
# Cloudflare:
# CLOUDFLARE_API_TOKEN=...
